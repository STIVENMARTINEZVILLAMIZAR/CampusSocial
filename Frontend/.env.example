# production = app real (Figma sin barra de diseño). Omitir o design = vista 8 pantallas
VITE_APP_MODE=production

# Google REAL (obligatorio para "Continuar con Google"):
# bash ../scripts/sync-firebase-web-env.sh
# o copia apiKey, appId, messagingSenderId desde Firebase Console
# No dejes vacío: provoca auth/invalid-api-key. Placeholder local (solo UI):
# VITE_FIREBASE_API_KEY=local-dev-placeholder
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=campussocial-f56a0.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=campussocial-f56a0
VITE_FIREBASE_STORAGE_BUCKET=campussocial-f56a0.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Local: Auth/Firestore en nube; solo Functions en emulador (recomendado con npm run dev en Backend)
VITE_USE_FIREBASE_EMULATOR=false
VITE_USE_FUNCTIONS_EMULATOR=true
VITE_USE_AUTH_EMULATOR=false

# Postiz (alternativa a OAuth LinkedIn)
# VITE_POSTIZ_URL=https://postiz.com

# URL pública de privacidad (LinkedIn/Meta) — tras deploy:
# https://campussocial-f56a0.web.app/privacidad

# LinkedIn OAuth — debe coincidir EXACTO con LinkedIn Developers → Auth
VITE_LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:5173/oauth/linkedin
