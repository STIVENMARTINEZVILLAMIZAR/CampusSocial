{
  "name": "campus-social-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "npm run dev",
    "dev:kill": "powershell -ExecutionPolicy Bypass -File ../scripts/kill-emulator-ports.ps1",
    "dev": "bash run-dev.sh",
    "dev:win": "npm run build && cd .. && firebase emulators:start --only functions,firestore,auth,storage",
    "dev:linux": "bash run-dev.sh",
    "seed": "node ../scripts/seed-firestore.mjs",
    "init-db": "node ../scripts/init-colecciones-firestore.mjs",
    "serve": "npm run dev",
    "deploy": "cd .. && firebase deploy --only functions"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^6.3.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "typescript": "^5.7.0"
  }
}
