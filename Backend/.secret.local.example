# Copiar a Backend/.secret.local (único archivo; no crear .secret.local en la raíz del repo)
AI_PROVIDER=gemini

# Obtener en https://aistudio.google.com/apikey (NO usar VITE_FIREBASE_API_KEY del Frontend)
GEMINI_API_KEY=tu_clave_gemini_aqui

# gemini-2.5-flash funciona con clave nueva; si hay 403/429 prueba gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

# Imagen IA (Nano Banana): gemini-2.5-flash-image o imagen-4.0-fast-generate-001
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Anthropic (opcional, de pago)
# ANTHROPIC_API_KEY=sk-ant-...

# n8n local (Docker) — ver docs/N8N_DOCKER.md
# N8N_WEBHOOK_URL=http://127.0.0.1:5678/webhook/campus-post-form
# N8N_WEBHOOK_SECRET=elige-un-secreto-largo-aqui

# Make.com (alternativa en la nube, opcional)
# MAKE_WEBHOOK_URL=https://hook.eu1.make.com/xxxxxxxx
# MAKE_WEBHOOK_SECRET=un-secreto-largo

# LinkedIn OAuth — ver docs/LINKEDIN_OAUTH.md
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_REDIRECT_URI=https://us-central1-campussocial-f56a0.cloudfunctions.net/linkedinOAuthCallback
# APP_FRONTEND_URL=https://campussocial-f56a0.web.app

# Meta Graph API (próximo paso)
# META_APP_ID=
# META_APP_SECRET=
# META_REDIRECT_URI=
